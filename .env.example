# ── Required ───────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
JWT_SECRET_KEY=change-me-to-a-random-32-char-string

# ── Database ───────────────────────────────────────────────────────────────────
# Local PostgreSQL (set up by setup.sh):
DATABASE_URL=postgresql://commodex:commodex_pass@localhost:5432/commodex
# SQLite (dev/testing only):
# DATABASE_URL=sqlite:///commodex.db

# ── App URL (used in email links) ─────────────────────────────────────────────
APP_URL=http://139.84.223.215
# With domain: APP_URL=https://yourdomain.com

# ── Email alerts (SMTP) ────────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_gmail_app_password
FROM_EMAIL=your@gmail.com

# ── Optional data sources ──────────────────────────────────────────────────────
# EIA (energy supply data — free at eia.gov/opendata):
EIA_API_KEY=

# FRED (DXY, 10Y yield, industrial production, CPI — free at fred.stlouisfed.org):
FRED_API_KEY=
